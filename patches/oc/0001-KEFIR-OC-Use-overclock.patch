+/* - Mariko CPU DVFS Table:
+ * 2397000 might not work for some SoCs.
+ */
+.marikoCpuDvfsTable = {
+    {  204000, {  721589, -12695, 27 }, {} },
+    {  306000, {  747134, -14195, 27 }, {} },
+    {  408000, {  776324, -15705, 27 }, {} },
