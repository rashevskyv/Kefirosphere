+    { 1224000, { 1141084, -27735, 27 }, { 1120000 } },
+    { 1326000, { 1203084, -29245, 27 }, { 1120000 } },
+    { 1428000, { 1268729, -30745, 27 }, { 1120000 } },
+    { 1581000, { 1374032, -33005, 27 }, { 1120000 } },
