+/* - Erista GPU DVFS Table:
+ */
+.eristaGpuDvfsTable = {
+    {   76800, { }, {  814294, 8144, -940, 808, -21583, 226 } },
+    {  153600, { }, {  856185, 8144, -940, 808, -21583, 226 } },
