+/*
+ * 4IFIR Autokeys — detector + chainload to silent Lockpick.
+ *
+ * Runs once per boot from ipl_main (after SD mount, before _auto_launch).
+ * Detects whether the HOS pkg1 on SysMMC or EmuMMC differs from what was
+ * dumped last time, and if so writes a request marker and jumps to
+ * bootloader/sys/lockpick.bin which performs the actual dump and then
+ * chainloads hekate back via bootloader/update.bin.
+ *
+ * Intentionally contains NO crypto — all key derivation lives in Lockpick.
+ *
+ * Copyright (c) 2026 4IFIR
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+
+#include <string.h>
+
+#include <bdk.h>
+
+#include "autokeys.h"
+#include "../config.h"
+#include "../hos/pkg1.h"
+#include "../storage/emummc.h"
+
+#include <libs/fatfs/ff.h>
+#include <mem/heap.h>
+#include <storage/emmc.h>
+#include <storage/sd.h>
+#include <storage/sdmmc.h>
+
+/* ---------- Constants ---------- */
+
+#define AK_STATE_MAGIC    0x49344B41u   /* 'AK4I' */
+#define AK_STATE_VER      2             /* v1 was dead-end in-hekate dumper; v2 is split-brain */
+
+#define AK_REQ_MAGIC      0x5152414Bu   /* 'AKRQ' */
+#define AK_REQ_VER        1
+
+#define AK_MAX_RETRY      3             /* Lockpick gets 3 chances before we mark .failed */
+
+/* Paths are SD-root relative. FatFs is built with FF_STR_VOLUME_ID=0 here,
+ * so any "sd:/" prefix would become part of the filename and silently fail. */
+#define AK_PATH_PRODKEYS  "switch/prod.keys"
+#define AK_PATH_STATE     "bootloader/sys/autokeys.bin"
+#define AK_PATH_REQUEST   "bootloader/sys/autokeys.request"
+#define AK_PATH_DISABLE   "bootloader/sys/autokeys.disable"
+#define AK_PATH_FORCE     "bootloader/sys/autokeys.force"
+#define AK_PATH_FAILED    "bootloader/sys/autokeys.failed"
+#define AK_PATH_LOCKPICK  "bootloader/sys/lockpick.bin"
+#define AK_PATH_LOG       "bootloader/sys/autokeys.log"
+
+/* Enable to emit a small per-boot diagnostic log at AK_PATH_LOG.
+ * Cost: ~500B code + 512B static buffer. Leave on until autodump is proven stable. */
+#define AK_DEBUG_LOG 1
+
+/* ---------- File layouts ---------- */
+
+typedef struct {
+	u32 magic;
+	u8  version;
+	u8  chip_t210b01;
+	u8  reserved[2];
+	u8  sys_timestamp[14];
+	u8  sys_mkey;
+	u8  sys_present;
+	u8  emu_timestamp[14];
+	u8  emu_mkey;
+	u8  emu_present;
+} __attribute__((packed)) ak_state_t;
+
+typedef struct {
+	u32 magic;
+	u8  version;
+	u8  retry;         /* 0..AK_MAX_RETRY; Lockpick increments on entry */
+	u8  target_mask;   /* bit0=sys, bit1=emu */
+	u8  reserved;
+	u8  sys_timestamp[14];
+	u8  sys_mkey;
+	u8  emu_timestamp[14];
+	u8  emu_mkey;
+} __attribute__((packed)) ak_request_t;
+
+typedef struct {
+	u8  timestamp[14];
+	u8  mkey;
+	u8  present;
+} ak_nand_info_t;
+
+/* Forward decl of hekate-internal payload launcher in bootloader/main.c.
+ * (static was removed there to expose this single call site.) */
+void _launch_payload(char *path, bool update, bool clear_screen);
+
+/* ---------- Optional diagnostic log ---------- */
+
+#ifdef AK_DEBUG_LOG
+static char ak_log_buf[512];
+static u32  ak_log_len = 0;
+
+static void _ak_log_str(const char *s)
+{
+	while (*s && ak_log_len < sizeof(ak_log_buf) - 1)
+		ak_log_buf[ak_log_len++] = *s++;
+	ak_log_buf[ak_log_len] = 0;
+}
+
+static void _ak_log_hex_u8(u8 v)
+{
+	if (ak_log_len + 2 >= sizeof(ak_log_buf) - 1) return;
+	static const char lut[] = "0123456789abcdef";
+	ak_log_buf[ak_log_len++] = lut[(v >> 4) & 0xF];
+	ak_log_buf[ak_log_len++] = lut[v & 0xF];
+	ak_log_buf[ak_log_len] = 0;
+}
+
+static void _ak_log_ts(const u8 *ts14)
+{
+	for (u32 i = 0; i < 14 && ak_log_len < sizeof(ak_log_buf) - 1; i++)
+		ak_log_buf[ak_log_len++] = ts14[i] ? ts14[i] : '0';
+	ak_log_buf[ak_log_len] = 0;
+}
+
+static void _ak_log_flush(void)
+{
+	if (ak_log_len == 0) return;
+	FIL fp;
+	f_mkdir("bootloader");
+	f_mkdir("bootloader/sys");
+	if (f_open(&fp, AK_PATH_LOG, FA_CREATE_ALWAYS | FA_WRITE)) return;
+	f_write(&fp, ak_log_buf, ak_log_len, NULL);
+	f_close(&fp);
+}
+
+#define AK_LOG(s)    _ak_log_str(s)
+#define AK_LOGX(v)   _ak_log_hex_u8((u8)(v))
+#define AK_LOGTS(t)  _ak_log_ts(t)
+#define AK_FLUSH()   _ak_log_flush()
+#else
+#define AK_LOG(s)    ((void)0)
+#define AK_LOGX(v)   ((void)0)
+#define AK_LOGTS(t)  ((void)0)
+#define AK_FLUSH()   ((void)0)
+#endif
+
+/* ---------- File helpers ---------- */
+
+static bool _ak_read_state(ak_state_t *out)
+{
+	FIL fp;
+	UINT br = 0;
+	if (f_open(&fp, AK_PATH_STATE, FA_READ | FA_OPEN_EXISTING))
+		return false;
+	FRESULT r = f_read(&fp, out, sizeof(*out), &br);
+	f_close(&fp);
+	if (r != FR_OK || br != sizeof(*out))
+		return false;
+	if (out->magic != AK_STATE_MAGIC || out->version != AK_STATE_VER)
+		return false;
+	return true;
+}
+
+static bool _ak_read_request(ak_request_t *out)
+{
+	FIL fp;
+	UINT br = 0;
+	if (f_open(&fp, AK_PATH_REQUEST, FA_READ | FA_OPEN_EXISTING))
+		return false;
+	FRESULT r = f_read(&fp, out, sizeof(*out), &br);
+	f_close(&fp);
+	if (r != FR_OK || br != sizeof(*out))
+		return false;
+	if (out->magic != AK_REQ_MAGIC || out->version != AK_REQ_VER)
+		return false;
+	return true;
+}
+
+static void _ak_write_request(const ak_request_t *req)
+{
+	FIL fp;
+	f_mkdir("bootloader");
+	f_mkdir("bootloader/sys");
+	if (f_open(&fp, AK_PATH_REQUEST, FA_CREATE_ALWAYS | FA_WRITE))
+		return;
+	f_write(&fp, req, sizeof(*req), NULL);
+	f_close(&fp);
+}
+
+static void _ak_mark_failed(void)
+{
+	FIL fp;
+	f_mkdir("bootloader");
+	f_mkdir("bootloader/sys");
+	if (f_open(&fp, AK_PATH_FAILED, FA_CREATE_ALWAYS | FA_WRITE))
+		return;
+	/* Content doesn't matter — presence is the signal. Write a tiny hint. */
+	static const char msg[] = "Lockpick autodump failed too many times. "
+	                          "Run Lockpick manually, then delete this file.\n";
+	f_write(&fp, msg, sizeof(msg) - 1, NULL);
+	f_close(&fp);
+}
+
+/* ---------- NAND probe ---------- */
+
+/* Reads pkg1 header from whatever NAND is currently routed by
+ * emu_cfg + h_cfg.emummc_force_disable. Fills info. Returns true if
+ * an identified or at least timestamp-readable pkg1 was found. */
+static bool _ak_probe_current_nand(ak_nand_info_t *info)
+{
+	memset(info, 0, sizeof(*info));
+
+	/* 1 sector (512B) is enough: bl_hdr_t210b01_t (0x170) + pk1_hdr_t (0x20) = 0x190. */
+	u8 *buf = (u8 *)malloc(EMMC_BLOCKSIZE);
+	if (!buf)
+		return false;
+
+	bool ok = false;
+
+	if (emummc_storage_set_mmc_partition(EMMC_BOOT0))
+		goto out;
+
+	/* PKG1_BOOTLOADER_MAIN_OFFSET is already a sector count (defined as bytes/EMMC_BLOCKSIZE). */
+	if (emummc_storage_read(PKG1_BOOTLOADER_MAIN_OFFSET, 1, buf))
+		goto out;
+
+	const u32 pk1_offset = h_cfg.t210b01 ? sizeof(bl_hdr_t210b01_t) : 0;
+	const pk1_hdr_t *hdr = (const pk1_hdr_t *)(buf + pk1_offset);
+
+	/* Raw header fields — plaintext, no decryption needed. */
+	memcpy(info->timestamp, hdr->timestamp, 14);
+	info->present = 1;
+
+	/* Try to resolve to a known pkg1 id for a clean mkey byte.
+	 * Unknown (future) timestamps still get recorded; Lockpick decides if it can handle them. */
+	const pkg1_id_t *id = pkg1_identify(buf + pk1_offset);
+	info->mkey = id ? (u8)id->mkey : hdr->keygen;
+
+	ok = true;
+
+out:
+	free(buf);
+	return ok;
+}
+
+/* ---------- Main entry ---------- */
+
+void autokeys_dump_if_needed(void)
+{
+	/* Mute gfx first: pkg1_identify() unconditionally gfx_printf's the timestamp
+	 * and we don't want that appearing in the framebuffer for a silent detector. */
+	bool saved_mute = gfx_con.mute;
+	gfx_con.mute = true;
+
+	AK_LOG("autokeys enter; t210b01="); AK_LOGX(h_cfg.t210b01 ? 1 : 0); AK_LOG("\n");
+
+	FILINFO fno;
+
+	/* Opt-out marker: cheapest possible check. */
+	if (!f_stat(AK_PATH_DISABLE, &fno)) {
+		AK_LOG("skip: disable marker\n");
+		goto done;
+	}
+
+	/* Pre-flight: if the silent Lockpick binary is missing, do nothing.
+	 * Writing a request without a handler would trap us in a dead cycle. */
+	if (f_stat(AK_PATH_LOCKPICK, &fno)) {
+		AK_LOG("skip: lockpick.bin missing at " AK_PATH_LOCKPICK "\n");
+		goto done;
+	}
+	AK_LOG("lockpick.bin found\n");
+
+	/* Retry budget: if a request from a previous boot already reached the cap,
+	 * mark failure and stop re-triggering until the user intervenes. */
+	ak_request_t prev_req = {0};
+	bool have_req = _ak_read_request(&prev_req);
+	u8 next_retry = 0;
+	AK_LOG("prev_req="); AK_LOGX(have_req ? 1 : 0);
+	if (have_req) { AK_LOG(" retry="); AK_LOGX(prev_req.retry); }
+	AK_LOG("\n");
+	if (have_req) {
+		if (prev_req.retry >= AK_MAX_RETRY) {
+			AK_LOG("give up: retry cap hit\n");
+			_ak_mark_failed();
+			f_unlink(AK_PATH_REQUEST);
+			goto done;
+		}
+		/* Lockpick increments retry on entry; we carry whatever it wrote. */
+		next_retry = prev_req.retry;
+	}
+
+	/* --------- Probe both NANDs. --------- */
+
+	emummc_load_cfg();
+	bool has_emu_cfg = (emu_cfg.enabled && (emu_cfg.sector || emu_cfg.path));
+
+	bool orig_force_disable = h_cfg.emummc_force_disable;
+	u32  orig_enabled       = emu_cfg.enabled;
+
+	ak_nand_info_t sys_info = {0};
+	ak_nand_info_t emu_info = {0};
+
+	/* SysMMC probe. */
+	AK_LOG("sys probe...\n");
+	h_cfg.emummc_force_disable = true;
+	emu_cfg.enabled = 0;
+	int sys_rc = emummc_storage_init_mmc();
+	AK_LOG("  sys init_rc="); AK_LOGX(sys_rc); AK_LOG("\n");
+	if (sys_rc == 0) {
+		_ak_probe_current_nand(&sys_info);
+		emmc_end();   /* physical eMMC only — leaves SD alone */
+	}
+	h_cfg.emummc_force_disable = orig_force_disable;
+	emu_cfg.enabled = orig_enabled;
+	AK_LOG("  sys present="); AK_LOGX(sys_info.present);
+	AK_LOG(" mkey="); AK_LOGX(sys_info.mkey);
+	AK_LOG(" ts="); AK_LOGTS(sys_info.timestamp); AK_LOG("\n");
+
+	/* EmuMMC probe (only if configured). */
+	if (has_emu_cfg) {
+		AK_LOG("emu probe...\n");
+		h_cfg.emummc_force_disable = false;
+		emu_cfg.enabled = 1;
+		int emu_rc = emummc_storage_init_mmc();
+		AK_LOG("  emu init_rc="); AK_LOGX(emu_rc); AK_LOG("\n");
+		if (emu_rc == 0) {
+			_ak_probe_current_nand(&emu_info);
+			emmc_end();
+		}
+		h_cfg.emummc_force_disable = orig_force_disable;
+		emu_cfg.enabled = orig_enabled;
+		AK_LOG("  emu present="); AK_LOGX(emu_info.present);
+		AK_LOG(" mkey="); AK_LOGX(emu_info.mkey);
+		AK_LOG(" ts="); AK_LOGTS(emu_info.timestamp); AK_LOG("\n");
+	} else {
+		AK_LOG("emu skip: not configured\n");
+	}
+
+	if (!sys_info.present && !emu_info.present) {
+		AK_LOG("skip: no NAND present\n");
+		goto done;
+	}
+
+	/* --------- Compare with last known state. --------- */
+
+	ak_state_t prev = {0};
+	bool have_prev = _ak_read_state(&prev);
+	if (have_prev && prev.chip_t210b01 != (h_cfg.t210b01 ? 1 : 0))
+		have_prev = false;
+
+	bool sys_changed = sys_info.present && (!have_prev
+		|| memcmp(prev.sys_timestamp, sys_info.timestamp, 14) != 0
+		|| prev.sys_mkey != sys_info.mkey
+		|| prev.sys_present != sys_info.present);
+
+	bool emu_changed = emu_info.present && (!have_prev
+		|| memcmp(prev.emu_timestamp, emu_info.timestamp, 14) != 0
+		|| prev.emu_mkey != emu_info.mkey
+		|| prev.emu_present != emu_info.present);
+
+	bool emu_removed  = have_prev && prev.emu_present && !emu_info.present;
+	bool keys_missing = (f_stat(AK_PATH_PRODKEYS, &fno) != FR_OK);
+	bool force_dump   = (f_stat(AK_PATH_FORCE, &fno) == FR_OK);
+
+	AK_LOG("changed: sys="); AK_LOGX(sys_changed);
+	AK_LOG(" emu="); AK_LOGX(emu_changed);
+	AK_LOG(" removed="); AK_LOGX(emu_removed);
+	AK_LOG(" missing="); AK_LOGX(keys_missing);
+	AK_LOG(" force="); AK_LOGX(force_dump); AK_LOG("\n");
+
+	if (!sys_changed && !emu_changed && !emu_removed && !keys_missing && !force_dump) {
+		AK_LOG("skip: nothing changed\n");
+		goto done;
+	}
+
+	/* --------- Something changed: arm request and hand off to Lockpick. --------- */
+
+	ak_request_t req = {0};
+	req.magic       = AK_REQ_MAGIC;
+	rewarning: in the working copy of 'bootloader/keys/autokeys.h', LF will be replaced by CRLF the next time Git touches it
q.version     = AK_REQ_VER;
+	req.retry       = next_retry;
+	req.target_mask = (u8)((sys_info.present ? 0x01 : 0) | (emu_info.present ? 0x02 : 0));
+	memcpy(req.sys_timestamp, sys_info.timestamp, 14);
+	req.sys_mkey = sys_info.mkey;
+	memcpy(req.emu_timestamp, emu_info.timestamp, 14);
+	req.emu_mkey = emu_info.mkey;
+	_ak_write_request(&req);
+
+	AK_LOG("launch lockpick.bin; retry="); AK_LOGX(req.retry);
+	AK_LOG(" mask="); AK_LOGX(req.target_mask); AK_LOG("\n");
+	AK_FLUSH();
+
+	/* Restore gfx mute: Lockpick will decide its own display policy. */
+	gfx_con.mute = saved_mute;
+
+	/* One-way chainload. _launch_payload does sd_end + hw_deinit internally. */
+	_launch_payload((char *)AK_PATH_LOCKPICK, false, false);
+
+	/* If we're still here, the launch failed (e.g., file too big at load time).
+	 * Delete the request so we don't infinitely re-try on next boot. */
+	sd_mount();
+	AK_LOG("launch returned (failed); request deleted\n");
+	AK_FLUSH();
+	f_unlink(AK_PATH_REQUEST);
+	return;
+
+done:
+	/* Downstream code (_auto_launch, nyx) relies on SD being mounted. Probing toggled
+	 * emu state and may have ended eMMC — make sure SD is still usable. */
+	sd_mount();
+	AK_FLUSH();
+	gfx_con.mute = saved_mute;
+}
