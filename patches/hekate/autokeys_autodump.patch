+/*
+ * 4IFIR Lockpick silent dispatcher — runs before the main menu and
+ * honours the bootloader/sys/autokeys.request marker placed by hekate.
+ *
+ * If the marker exists, performs a silent key dump via dump_keys_silent(),
+ * writes bootloader/sys/autokeys.bin state, removes the marker, and
+ * chainloads bootloader/update.bin (hekate) — one-way.
+ *
+ * If the marker is missing, does nothing and returns immediately so the
+ * normal UI menu loop runs as usual.
+ *
+ * Copyright (c) 2026 4IFIR
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+
+#ifndef _AUTOKEYS_SILENT_H_
+#define _AUTOKEYS_SILENT_H_
+
+void autokeys_silent_dispatch(void);
+
+#endif
diff --git a/source/auto/silent.c b/source/auto/silent.c
new file mode 100644
--- /dev/null
+++ b/source/auto/silent.c
@@ -0,0 +1,199 @@
+/*
+ * 4IFIR Lockpick silent dispatcher.
+ *
+ * Reads sd:/bootloader/sys/autokeys.request (written by hekate's detector),
+ * runs silent dumps via dump_keys_silent() for the targeted NAND(s),
+ * writes sd:/bootloader/sys/autokeys.bin on success, removes the request,
+ * and chainloads hekate via sd:/bootloader/update.bin. One-way jump.
+ *
+ * Copyright (c) 2026 4IFIR
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+
+#include "silent.h"
+
+#include <string.h>
+
+#include <display/di.h>
+#include <gfx_utils.h>
+#include <libs/fatfs/ff.h>
+#include <mem/minerva.h>
+
+#include "../config.h"
+#include "../keys/keys.h"
+#include "../storage/emummc.h"
+
+extern hekate_config h_cfg;
+extern int launch_payload(char *path, bool clear_screen);
+
+/* ---------- Constants ---------- */
+
+#define AK_STATE_MAGIC    0x49344B41u   /* 'AK4I' — must match hekate's autokeys.c */
+#define AK_STATE_VER      2
+#define AK_REQ_MAGIC      0x5152414Bu   /* 'AKRQ' */
+#define AK_REQ_VER        1
+#define AK_MAX_RETRY      3
+
+/* Lockpick's FatFs is built with FF_STR_VOLUME_ID=1 — prefixes are optional but
+ * the existing keys.c uses "sd:/" consistently, we match that style. */
+#define AK_PATH_STATE     "sd:/bootloader/sys/autokeys.bin"
+#define AK_PATH_REQUEST   "sd:/bootloader/sys/autokeys.request"
+#define AK_PATH_FAILED    "sd:/bootloader/sys/autokeys.failed"
+#define AK_PATH_UPDATE    "bootloader/update.bin"
+
+/* ---------- File layouts (must match hekate) ---------- */
+
+typedef struct {
+	u32 magic;
+	u8  version;
+	u8  chip_t210b01;
+	u8  reserved[2];
+	u8  sys_timestamp[14];
+	u8  sys_mkey;
+	u8  sys_present;
+	u8  emu_timestamp[14];
+	u8  emu_mkey;
+	u8  emu_present;
+} __attribute__((packed)) ak_state_t;
+
+typedef struct {
+	u32 magic;
+	u8  version;
+	u8  retry;
+	u8  target_mask;
+	u8  reserved;
+	u8  sys_timestamp[14];
+	u8  sys_mkey;
+	u8  emu_timestamp[14];
+	u8  emu_mkey;
+} __attribute__((packed)) ak_request_t;
+
+/* ---------- Helpers ---------- */
+
+static bool _ak_read_request(ak_request_t *out)
+{
+	FIL fp;
+	UINT br = 0;
+	if (f_open(&fp, AK_PATH_REQUEST, FA_READ | FA_OPEN_EXISTING))
+		return false;
+	FRESULT r = f_read(&fp, out, sizeof(*out), &br);
+	f_close(&fp);
+	if (r != FR_OK || br != sizeof(*out))
+		return false;
+	if (out->magic != AK_REQ_MAGIC || out->version != AK_REQ_VER)
+		return false;
+	return true;
+}
+
+static void _ak_write_request(const ak_request_t *req)
+{
+	FIL fp;
+	f_mkdir("sd:/bootloader");
+	f_mkdir("sd:/bootloader/sys");
+	if (f_open(&fp, AK_PATH_REQUEST, FA_CREATE_ALWAYS | FA_WRITE))
+		return;
+	f_write(&fp, req, sizeof(*req), NULL);
+	f_close(&fp);
+}
+
+static void _ak_write_state(const ak_state_t *st)
+{
+	FIL fp;
+	f_mkdir("sd:/bootloader");
+	f_mkdir("sd:/bootloader/sys");
+	if (f_open(&fp, AK_PATH_STATE, FA_CREATE_ALWAYS | FA_WRITE))
+		return;
+	f_write(&fp, st, sizeof(*st), NULL);
+	f_close(&fp);
+}
+
+static void _ak_mark_failed(void)
+{
+	FIL fp;
+	f_mkdir("sd:/bootloader");
+	f_mkdir("sd:/bootloader/sys");
+	if (f_open(&fp, AK_PATH_FAILED, FA_CREATE_ALWAYS | FA_WRITE))
+		return;
+	static const char msg[] = "Lockpick autodump failed. "
+	                          "Run Lockpick manually, then delete this file.\n";
+	f_write(&fp, msg, sizeof(msg) - 1, NULL);
+	f_close(&fp);
+}
+
+/* ---------- Main entry ---------- */
+
+void autokeys_silent_dispatch(void)
+{
+	ak_request_t req = {0};
+	if (!_ak_read_request(&req))
+		return; /* no marker → normal manual UI flow */
+
+	/* Retry cap: if we already burned AK_MAX_RETRY attempts, give up.
+	 * (Hekate handles this too, but we double-check in case Lockpick was
+	 * launched by something else that didn't enforce the cap.) */
+	if (req.retry >= AK_MAX_RETRY) {
+		_ak_mark_failed();
+		f_unlink(AK_PATH_REQUEST);
+		return;
+	}
+
+	/* Checkpoint: bump retry and rewrite so the counter survives any subsequent crash. */
+	req.retry++;
+	_ak_write_request(&req);
+
+	/* Silent from here on: mute console, kill backlight. */
+	gfx_con.mute = true;
+	display_backlight_brightness(0, 0);
+
+	u32 total_keys = 0;
+	bool emu_targeted = (req.target_mask & 0x02) != 0;
+
+	/* ---------- Sys pass ---------- */
+	if (req.target_mask & 0x01) {
+		h_cfg.emummc_force_disable = true;
+		emu_cfg.enabled = 0;
+		u32 n = dump_keys_silent();
+		if (n > 0)
+			total_keys += n;
+	}
+
+	/* ---------- Emu pass ---------- */
+	/* Writes prod.keys (overwrites sys pass — content is equivalent by master-key
+	 * tables anyway) and title.keys from emu's installed tickets. If emu has no
+	 * tickets, title.keys from the sys pass stays intact (we never renamed it). */
+	if (emu_targeted) {
+		emummc_load_cfg();
+		/* Only run if emu is actually configured. (target_mask may be stale.) */
+		if (emu_cfg.sector != 0 || emu_cfg.path != NULL) {
+			h_cfg.emummc_force_disable = false;
+			emu_cfg.enabled = 1;
+			u32 n = dump_keys_silent();
+			if (n > 0)
+				total_keys += n;
+		}
+	}
+
+	/* ---------- Commit on success ---------- */
+	if (total_keys > 0) {
+		ak_state_t st = {0};
+		st.magic        = AK_STATE_MAGIC;
+		st.version      = AK_STATE_VER;
+		st.chip_t210b01 = h_cfg.t210b01 ? 1 : 0;
+		memcpy(st.sys_timestamp, req.sys_timestamp, 14);
+		st.sys_mkey    = req.sys_mkey;
+		st.sys_present = (req.target_mask & 0x01) ? 1 : 0;
+		memcpy(st.emu_timestamp, req.emu_timestamp, 14);
+		st.emu_mkey    = req.emu_mkey;
+		st.emu_present = (req.target_mask & 0x02) ? 1 : 0;
+		_ak_write_state(&st);
+
+		f_unlink(AK_PATH_REQUEST);
+	}
+	/* On failure: leave request in place with bumped retry — hekate will retry or
+	 * give up after AK_MAX_RETRY. */
+
+	/* Chainload back to hekate. One-way. If this returns, it failed;
+	 * unmute so the user sees the error banner and drops into Lockpick's menu. */
+	launch_payload(AK_PATH_UPDATE, false);
+	gfx_con.mute = false;
+}

