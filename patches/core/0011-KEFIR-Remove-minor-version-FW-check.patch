From 85f241425b0ce1bb0a98f6866c60cc4695cae898 Mon Sep 17 00:00:00 2001
From: rashevskyv <rashevsky.v@gmail.com>
Date: Mon, 13 Apr 2026 01:32:43 +0300
Subject: [PATCH 11/14] KEFIR: Remove minor version FW check

---
 libraries/libstratosphere/source/hos/hos_version_api.cpp | 4 +---
 1 file changed, 1 insertion(+), 3 deletions(-)

diff --git a/libraries/libstratosphere/source/hos/hos_version_api.cpp b/libraries/libstratosphere/source/hos/hos_version_api.cpp
index db3d6f623..742b1dcc6 100644
--- a/libraries/libstratosphere/source/hos/hos_version_api.cpp
+++ b/libraries/libstratosphere/source/hos/hos_version_api.cpp
@@ -107,12 +107,10 @@ namespace ams::hos {
             /* there are no breaking IPC changes in minor updates. */
             {
                 constexpr u32 MaxMajor = (static_cast<u32>(hos::Version_Max) >> 24) & 0xFF;
-                constexpr u32 MaxMinor = (static_cast<u32>(hos::Version_Max) >> 16) & 0xFF;
 
                 const u32 major = (static_cast<u32>(current) >> 24) & 0xFF;
-                const u32 minor = (static_cast<u32>(current) >> 16) & 0xFF;
 
-                const bool is_safely_tryable_version = (current <= hos::Version_Max) || (major == MaxMajor && minor <= MaxMinor);
+                const bool is_safely_tryable_version = (current <= hos::Version_Max) || (major == MaxMajor);
                 AMS_ABORT_UNLESS(is_safely_tryable_version);
             }
 
